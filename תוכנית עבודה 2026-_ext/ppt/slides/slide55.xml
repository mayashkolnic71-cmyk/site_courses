typeface="Calibri" panose="020F0502020204030204" pitchFamily="34" charset="0"/></a:endParaRPr></a:p><a:p><a:pPr marL="342900" lvl="0" indent="-342900" algn="r" rtl="1"><a:buFont typeface="Symbol" panose="05050102010706020507" pitchFamily="18" charset="2"/><a:buChar char=""/></a:pPr><a:r><a:rPr lang="he-IL" sz="1100" dirty="0"><a:effectLst/><a:latin typeface="Calibri" panose="020F0502020204030204" pitchFamily="34" charset="0"/><a:ea typeface="Times New Roman" panose="02020603050405020304" pitchFamily="18" charset="0"/><a:cs typeface="Arial" panose="020B0604020202020204" pitchFamily="34" charset="0"/></a:rPr><a:t>בבירור מול מחלקות נמצאו 5 מטופלים עם תרופות אלו פעילות כאשר 4 מהם מחטיבת מונשמים (אחד מהם משנת 2022) דווח למנהל חטיבת מונשמים.</a:t></a:r><a:endParaRPr lang="en-US" sz="1100" dirty="0"><a:effectLst/><a:latin typeface="Calibri" panose="020F0502020204030204" pitchFamily="34" charset="0"/><a:ea typeface="Calibri" panose="020F0502020204030204" pitchFamily="34" charset="0"/></a:endParaRPr></a:p><a:p><a:pPr marL="457200" algn="r" rtl="1"><a:buNone/></a:pPr><a:r><a:rPr lang="en-US" sz="1100" dirty="0"><a:effectLst/><a:latin typeface="Arial" panose="020B0604020202020204" pitchFamily="34" charset="0"/><a:ea typeface="Calibri" panose="020F0502020204030204" pitchFamily="34" charset="0"/></a:rPr><a:t> </a:t></a:r><a:endParaRPr lang="en-US" sz="1100" dirty="0"><a:effectLst/><a:latin typeface="Calibri" panose="020F0502020204030204" pitchFamily="34" charset="0"/><a:ea typeface="Calibri" panose="020F0502020204030204" pitchFamily="34" charset="0"/></a:endParaRPr></a:p><a:p><a:pPr marL="457200" algn="r" rtl="1"><a:buNone/></a:pPr><a:r><a:rPr lang="he-IL" sz="1100" b="1" dirty="0"><a:effectLst/><a:latin typeface="Calibri" panose="020F0502020204030204" pitchFamily="34" charset="0"/><a:ea typeface="Calibri" panose="020F0502020204030204" pitchFamily="34" charset="0"/><a:cs typeface="Arial" panose="020B0604020202020204" pitchFamily="34" charset="0"/></a:rPr><a:t>שאלות שעולות מהאירוע: </a:t></a:r><a:endParaRPr lang="en-US" sz="1100" dirty="0"><a:effectLst/><a:latin typeface="Calibri" panose="020F0502020204030204" pitchFamily="34" charset="0"/><a:ea typeface="Calibri" panose="020F0502020204030204" pitchFamily="34" charset="0"/></a:endParaRPr></a:p><a:p><a:pPr marL="742950" lvl="1" indent="-285750" algn="r" rtl="1"><a:buFont typeface="+mj-lt"/><a:buAutoNum type="alphaLcPeriod"/></a:pPr><a:r><a:rPr lang="he-IL" sz="1100" u="sng" dirty="0"><a:effectLst/><a:latin typeface="Calibri" panose="020F0502020204030204" pitchFamily="34" charset="0"/><a:ea typeface="Times New Roman" panose="02020603050405020304" pitchFamily="18" charset="0"/><a:cs typeface="Arial" panose="020B0604020202020204" pitchFamily="34" charset="0"/></a:rPr><a:t>למה הנהלה רפואית וסיעודית לא הייתה מודעת למחסור ?</a:t></a:r><a:endParaRPr lang="en-US" sz="1100" dirty="0"><a:effectLst/><a:latin typeface="Calibri" panose="020F0502020204030204" pitchFamily="34" charset="0"/><a:ea typeface="Calibri" panose="020F0502020204030204" pitchFamily="34" charset="0"/></a:endParaRPr></a:p><a:p><a:pPr marL="685800" algn="r" rtl="1"><a:buNone/></a:pPr><a:r><a:rPr lang="he-IL" sz="1100" dirty="0"><a:effectLst/><a:latin typeface="Calibri" panose="020F0502020204030204" pitchFamily="34" charset="0"/><a:ea typeface="Calibri" panose="020F0502020204030204" pitchFamily="34" charset="0"/><a:cs typeface="Arial" panose="020B0604020202020204" pitchFamily="34" charset="0"/></a:rPr><a:t>יש הנחייה לשלוח מיל להנהלה רפואית וסיעודית ולאחיות אחראיות בכל מחסור תרופה או ציוד חסר קיים או צפוי כולל לוח זמנים. מיל זה נשלח על ידי בית מרקחת ובאחריותם לעדכן. לפי דברי הצוותים לא זכור מיל בנושא זה. </a:t></a:r><a:endParaRPr lang="en-US" sz="1100" dirty="0"><a:effectLst/><a:latin typeface="Calibri" panose="020F0502020204030204" pitchFamily="34" charset="0"/><a:ea typeface="Calibri" panose="020F0502020204030204" pitchFamily="34" charset="0"/></a:endParaRPr></a:p><a:p><a:pPr marL="742950" lvl="1" indent="-285750" algn="r" rtl="1"><a:buFont typeface="+mj-lt"/><a:buAutoNum type="alphaLcPeriod"/></a:pPr><a:r><a:rPr lang="he-IL" sz="1100" u="sng" dirty="0"><a:effectLst/><a:latin typeface="Calibri" panose="020F0502020204030204" pitchFamily="34" charset="0"/><a:ea typeface="Times New Roman" panose="02020603050405020304" pitchFamily="18" charset="0"/><a:cs typeface="Arial" panose="020B0604020202020204" pitchFamily="34" charset="0"/></a:rPr><a:t>למה הצוות הרפואי והסיעודי לא התרעה ?</a:t></a:r><a:endParaRPr lang="en-US" sz="1100" dirty="0"><a:effectLst/><a:latin typeface="Calibri" panose="020F0502020204030204" pitchFamily="34" charset="0"/><a:ea typeface="Calibri" panose="020F0502020204030204" pitchFamily="34" charset="0"/></a:endParaRPr></a:p><a:p><a:pPr marL="914400" algn="r" rtl="1"><a:buNone/></a:pPr><a:r><a:rPr lang="he-IL" sz="1100" dirty="0"><a:effectLst/><a:latin typeface="Calibri" panose="020F0502020204030204" pitchFamily="34" charset="0"/><a:ea typeface="Calibri" panose="020F0502020204030204" pitchFamily="34" charset="0"/><a:cs typeface="Arial" panose="020B0604020202020204" pitchFamily="34" charset="0"/></a:rPr><a:t>לא נתנה התרעה ועדכון מבית מרקחת במיל כנהוג, בבקרת תרופות שבועית שמבוצעת על ידי רופא ואחות לא נמסר על חסר בתרופה כי נרשם שהתרופה ניתנה ולא התריעו בפני אחות אחראית. כמו כן לא הועלתה שאלה באם יש צורך להמשיך בתרופה לאחר בדיקת </a:t></a:r><a:r><a:rPr lang="he-IL" sz="1100" dirty="0" err="1"><a:effectLst/><a:latin typeface="Calibri" panose="020F0502020204030204" pitchFamily="34" charset="0"/><a:ea typeface="Calibri" panose="020F0502020204030204" pitchFamily="34" charset="0"/><a:cs typeface="Arial" panose="020B0604020202020204" pitchFamily="34" charset="0"/></a:rPr><a:t>אומדני</a:t></a:r><a:r><a:rPr lang="he-IL" sz="1100" dirty="0"><a:effectLst/><a:latin typeface="Calibri" panose="020F0502020204030204" pitchFamily="34" charset="0"/><a:ea typeface="Calibri" panose="020F0502020204030204" pitchFamily="34" charset="0"/><a:cs typeface="Arial" panose="020B0604020202020204" pitchFamily="34" charset="0"/></a:rPr><a:t> פה שנעשו ותועדו. </a:t></a:r><a:endParaRPr lang="en-US" sz="1100" dirty="0"><a:effectLst/><a:latin typeface="Calibri" panose="020F0502020204030204" pitchFamily="34" charset="0"/><a:ea typeface="Calibri" panose="020F0502020204030204" pitchFamily="34" charset="0"/></a:endParaRPr></a:p><a:p><a:pPr marL="742950" lvl="1" indent="-285750" algn="r" rtl="1"><a:buFont typeface="+mj-lt"/><a:buAutoNum type="alphaLcPeriod"/></a:pPr><a:r><a:rPr lang="he-IL" sz="1100" u="sng" dirty="0"><a:effectLst/><a:latin typeface="Calibri" panose="020F0502020204030204" pitchFamily="34" charset="0"/><a:ea typeface="Times New Roman" panose="02020603050405020304" pitchFamily="18" charset="0"/><a:cs typeface="Arial" panose="020B0604020202020204" pitchFamily="34" charset="0"/></a:rPr><a:t>איזה מנגנוני בקרה קיימים במוסד בהתרעת תרופה חסרה?</a:t></a:r><a:endParaRPr lang="en-US" sz="1100" dirty="0"><a:effectLst/><a:latin typeface="Calibri" panose="020F0502020204030204" pitchFamily="34" charset="0"/><a:ea typeface="Calibri" panose="020F0502020204030204" pitchFamily="34" charset="0"/></a:endParaRPr></a:p><a:p><a:pPr marL="678815" algn="r" rtl="1"><a:buNone/></a:pPr><a:r><a:rPr lang="he-IL" sz="1100" dirty="0"><a:effectLst/><a:latin typeface="Calibri" panose="020F0502020204030204" pitchFamily="34" charset="0"/><a:ea typeface="Calibri" panose="020F0502020204030204" pitchFamily="34" charset="0"/><a:cs typeface="Arial" panose="020B0604020202020204" pitchFamily="34" charset="0"/></a:rPr><a:t>לא קיימת מערכת התרעה ממוחשבת אספקת התרופות מתבצעת ידנית לפי רשימת צריכה ידנית . קימת מערכת אנושית של רוקח בלבד, או אחות . </a:t></a:r><a:endParaRPr lang="en-US" sz="1100" dirty="0"><a:effectLst/><a:latin typeface="Calibri" panose="020F0502020204030204" pitchFamily="34" charset="0"/><a:ea typeface="Calibri" panose="020F0502020204030204" pitchFamily="34" charset="0"/></a:endParaRPr></a:p><a:p><a:pPr marL="678815" algn="r" rtl="1"><a:buNone/></a:pPr><a:r><a:rPr lang="he-IL" sz="1100" dirty="0"><a:effectLst/><a:latin typeface="Calibri" panose="020F0502020204030204" pitchFamily="34" charset="0"/><a:ea typeface="Calibri" panose="020F0502020204030204" pitchFamily="34" charset="0"/><a:cs typeface="Arial" panose="020B0604020202020204" pitchFamily="34" charset="0"/></a:rPr><a:t>באם האחות תדווח שלא ניתנה התרופה </a:t></a:r><a:r><a:rPr lang="he-IL" sz="1100" dirty="0" err="1"><a:effectLst/><a:latin typeface="Calibri" panose="020F0502020204030204" pitchFamily="34" charset="0"/><a:ea typeface="Calibri" panose="020F0502020204030204" pitchFamily="34" charset="0"/><a:cs typeface="Arial" panose="020B0604020202020204" pitchFamily="34" charset="0"/></a:rPr><a:t>בקרדקס</a:t></a:r><a:r><a:rPr lang="he-IL" sz="1100" dirty="0"><a:effectLst/><a:latin typeface="Calibri" panose="020F0502020204030204" pitchFamily="34" charset="0"/><a:ea typeface="Calibri" panose="020F0502020204030204" pitchFamily="34" charset="0"/><a:cs typeface="Arial" panose="020B0604020202020204" pitchFamily="34" charset="0"/></a:rPr><a:t> תרופות תשלח התרעה אוטומטית לדיווח סיעודי השוטף. </a:t></a:r><a:endParaRPr lang="en-US" sz="1100" dirty="0"><a:effectLst/><a:latin typeface="Calibri" panose="020F0502020204030204" pitchFamily="34" charset="0"/><a:ea typeface="Calibri" panose="020F0502020204030204" pitchFamily="34" charset="0"/></a:endParaRPr></a:p><a:p><a:pPr marL="742950" lvl="1" indent="-285750" algn="r" rtl="1"><a:buFont typeface="+mj-lt"/><a:buAutoNum type="alphaLcPeriod"/></a:pPr><a:r><a:rPr lang="he-IL" sz="1100" u="sng" dirty="0"><a:effectLst/><a:latin typeface="Calibri" panose="020F0502020204030204" pitchFamily="34" charset="0"/><a:ea typeface="Times New Roman" panose="02020603050405020304" pitchFamily="18" charset="0"/><a:cs typeface="Arial" panose="020B0604020202020204" pitchFamily="34" charset="0"/></a:rPr><a:t>אומדן פה האם מבוצע ובאיזה תדירות ? </a:t></a:r><a:endParaRPr lang="en-US" sz="1100" dirty="0"><a:effectLst/><a:latin typeface="Calibri" panose="020F0502020204030204" pitchFamily="34" charset="0"/><a:ea typeface="Calibri" panose="020F0502020204030204" pitchFamily="34" charset="0"/></a:endParaRPr></a:p><a:p><a:pPr marL="678815" algn="r" rtl="1"><a:buNone/></a:pPr><a:r><a:rPr lang="he-IL" sz="1100" dirty="0"><a:effectLst/><a:latin typeface="Calibri" panose="020F0502020204030204" pitchFamily="34" charset="0"/><a:ea typeface="Calibri" panose="020F0502020204030204" pitchFamily="34" charset="0"/><a:cs typeface="Arial" panose="020B0604020202020204" pitchFamily="34" charset="0"/></a:rPr><a:t>אומדן פה מבוצע אחת לחודש לפי דברי אחיות אחראיות  כאשר הדרישה אחת לשלושה חודשים במערכת הממוחשבת . כמו כן אין אחידות במחלקות ברצף הביצוע כפי שנאמר אחד לחודש. בבדיקה שנעשתה למטופלים המקבלים טיפול תרופתי חסר לריריות הפה נמצא תיעוד של אומדן פה תקין. </a:t></a:r><a:endParaRPr lang="en-US" sz="1100" dirty="0"><a:effectLst/><a:latin typeface="Calibri" panose="020F0502020204030204" pitchFamily="34" charset="0"/><a:ea typeface="Calibri" panose="020F0502020204030204" pitchFamily="34" charset="0"/></a:endParaRPr></a:p><a:p><a:pPr marL="678815" algn="r" rtl="1"><a:buNone/></a:pPr><a:r><a:rPr lang="en-US" sz="1100" b="1" dirty="0"><a:effectLst/><a:latin typeface="Arial" panose="020B0604020202020204" pitchFamily="34" charset="0"/><a:ea typeface="Calibri" panose="020F0502020204030204" pitchFamily="34" charset="0"/></a:rPr><a:t> </a:t></a:r><a:endParaRPr lang="en-US" sz="1100" dirty="0"><a:effectLst/><a:latin typeface="Calibri" panose="020F0502020204030204" pitchFamily="34" charset="0"/><a:ea typeface="Calibri" panose="020F0502020204030204" pitchFamily="34" charset="0"/></a:endParaRPr></a:p><a:p><a:pPr marL="678815" algn="r" rtl="1"><a:buNone/></a:pPr><a:r><a:rPr lang="he-IL" sz="1100" b="1" dirty="0"><a:effectLst/><a:latin typeface="Calibri" panose="020F0502020204030204" pitchFamily="34" charset="0"/><a:ea typeface="Calibri" panose="020F0502020204030204" pitchFamily="34" charset="0"/><a:cs typeface="Arial" panose="020B0604020202020204" pitchFamily="34" charset="0"/></a:rPr><a:t>המלצות :</a:t></a:r><a:endParaRPr lang="en-US" sz="1100" dirty="0"><a:effectLst/><a:latin typeface="Calibri" panose="020F0502020204030204" pitchFamily="34" charset="0"/><a:ea typeface="Calibri" panose="020F0502020204030204" pitchFamily="34" charset="0"/></a:endParaRPr></a:p><a:p><a:pPr marL="742950" lvl="1" indent="-285750" algn="r" rtl="1"><a:buFont typeface="+mj-lt"/><a:buAutoNum type="arabicPeriod"/></a:pPr><a:r><a:rPr lang="he-IL" sz="1100" dirty="0"><a:effectLst/><a:latin typeface="Calibri" panose="020F0502020204030204" pitchFamily="34" charset="0"/><a:ea typeface="Times New Roman" panose="02020603050405020304" pitchFamily="18" charset="0"/><a:cs typeface="Arial" panose="020B0604020202020204" pitchFamily="34" charset="0"/></a:rPr><a:t>לעדכן הנחיות מילוי של אומדן פה במערכת הממוחשבת בתאום עם רכזת הזנה והאכלה – יאנה</a:t></a:r><a:endParaRPr lang="en-US" sz="1100" dirty="0"><a:effectLst/><a:latin typeface="Calibri" panose="020F0502020204030204" pitchFamily="34" charset="0"/><a:ea typeface="Calibri" panose="020F0502020204030204" pitchFamily="34" charset="0"/><a:cs typeface="Arial" panose="020B0604020202020204" pitchFamily="34" charset="0"/></a:endParaRPr></a:p><a:p><a:pPr marL="742950" lvl="1" indent="-285750" algn="r" rtl="1"><a:buFont typeface="+mj-lt"/><a:buAutoNum type="arabicPeriod"/></a:pPr><a:r><a:rPr lang="he-IL" sz="1100" dirty="0"><a:effectLst/><a:latin typeface="Calibri" panose="020F0502020204030204" pitchFamily="34" charset="0"/><a:ea typeface="Times New Roman" panose="02020603050405020304" pitchFamily="18" charset="0"/><a:cs typeface="Arial" panose="020B0604020202020204" pitchFamily="34" charset="0"/></a:rPr><a:t>אחיות אחראיות יבצעו בקרת טיפולי פה </a:t></a:r><a:r><a:rPr lang="he-IL" sz="1100" dirty="0" err="1"><a:effectLst/><a:latin typeface="Calibri" panose="020F0502020204030204" pitchFamily="34" charset="0"/><a:ea typeface="Times New Roman" panose="02020603050405020304" pitchFamily="18" charset="0"/><a:cs typeface="Arial" panose="020B0604020202020204" pitchFamily="34" charset="0"/></a:rPr><a:t>ואומדן</a:t></a:r><a:r><a:rPr lang="he-IL" sz="1100" dirty="0"><a:effectLst/><a:latin typeface="Calibri" panose="020F0502020204030204" pitchFamily="34" charset="0"/><a:ea typeface="Times New Roman" panose="02020603050405020304" pitchFamily="18" charset="0"/><a:cs typeface="Arial" panose="020B0604020202020204" pitchFamily="34" charset="0"/></a:rPr><a:t> פה באופן </a:t></a:r><a:r><a:rPr lang="he-IL" sz="1100" dirty="0" err="1"><a:effectLst/><a:latin typeface="Calibri" panose="020F0502020204030204" pitchFamily="34" charset="0"/><a:ea typeface="Times New Roman" panose="02020603050405020304" pitchFamily="18" charset="0"/><a:cs typeface="Arial" panose="020B0604020202020204" pitchFamily="34" charset="0"/></a:rPr><a:t>אקרעי</a:t></a:r><a:r><a:rPr lang="he-IL" sz="1100" dirty="0"><a:effectLst/><a:latin typeface="Calibri" panose="020F0502020204030204" pitchFamily="34" charset="0"/><a:ea typeface="Times New Roman" panose="02020603050405020304" pitchFamily="18" charset="0"/><a:cs typeface="Arial" panose="020B0604020202020204" pitchFamily="34" charset="0"/></a:rPr><a:t> ולרשימת המטופלים שמטופלים בטיפול תרופתי זה. – אחיות אחראיות מחלקה </a:t></a:r><a:endParaRPr lang="en-US" sz="1100" dirty="0"><a:effectLst/><a:latin typeface="Calibri" panose="020F0502020204030204" pitchFamily="34" charset="0"/><a:ea typeface="Calibri" panose="020F0502020204030204" pitchFamily="34" charset="0"/><a:cs typeface="Arial" panose="020B0604020202020204" pitchFamily="34" charset="0"/></a:endParaRPr></a:p><a:p><a:pPr marL="742950" lvl="1" indent="-285750" algn="r" rtl="1"><a:buFont typeface="+mj-lt"/><a:buAutoNum type="arabicPeriod"/></a:pPr><a:r><a:rPr lang="he-IL" sz="1100" dirty="0"><a:effectLst/><a:latin typeface="Calibri" panose="020F0502020204030204" pitchFamily="34" charset="0"/><a:ea typeface="Times New Roman" panose="02020603050405020304" pitchFamily="18" charset="0"/><a:cs typeface="Arial" panose="020B0604020202020204" pitchFamily="34" charset="0"/></a:rPr><a:t>הצוות הרפואי ישקול החלפת טיפול תרופתי או הפסקתו לאור אומדן פה ובדיקת הריריות. – אחראיות מנהל רפואי או איש מטעמו </a:t></a:r><a:endParaRPr lang="en-US" sz="1100" dirty="0"><a:effectLst/><a:latin typeface="Calibri" panose="020F0502020204030204" pitchFamily="34" charset="0"/><a:ea typeface="Calibri" panose="020F0502020204030204" pitchFamily="34" charset="0"/><a:cs typeface="Arial" panose="020B0604020202020204" pitchFamily="34" charset="0"/></a:endParaRPr></a:p><a:p><a:pPr marL="742950" lvl="1" indent="-285750" algn="r" rtl="1"><a:buFont typeface="+mj-lt"/><a:buAutoNum type="arabicPeriod"/></a:pPr><a:r><a:rPr lang="he-IL" sz="1100" dirty="0"><a:effectLst/><a:latin typeface="Calibri" panose="020F0502020204030204" pitchFamily="34" charset="0"/><a:ea typeface="Times New Roman" panose="02020603050405020304" pitchFamily="18" charset="0"/><a:cs typeface="Arial" panose="020B0604020202020204" pitchFamily="34" charset="0"/></a:rPr><a:t>אחות אחראית תעדכן את הרופאים והאחיות לצורך בבקרת תרופות לדווח ולשקול החלפת טיפול תרופתי בחסר.- אחראיות אחות אחראית </a:t></a:r><a:endParaRPr lang="en-US" sz="1100" dirty="0"><a:effectLst/><a:latin typeface="Calibri" panose="020F0502020204030204" pitchFamily="34" charset="0"/><a:ea typeface="Calibri" panose="020F0502020204030204" pitchFamily="34" charset="0"/><a:cs typeface="Arial" panose="020B0604020202020204" pitchFamily="34" charset="0"/></a:endParaRPr></a:p><a:p><a:pPr marL="742950" lvl="1" indent="-285750" algn="r" rtl="1"><a:buFont typeface="+mj-lt"/><a:buAutoNum type="arabicPeriod"/></a:pPr><a:r><a:rPr lang="he-IL" sz="1100" dirty="0"><a:effectLst/><a:latin typeface="Calibri" panose="020F0502020204030204" pitchFamily="34" charset="0"/><a:ea typeface="Times New Roman" panose="02020603050405020304" pitchFamily="18" charset="0"/><a:cs typeface="Arial" panose="020B0604020202020204" pitchFamily="34" charset="0"/></a:rPr><a:t>להדריך אחיות אחראיות לדווח במועד מתן תרופה שהתרופה לא ניתנה ובהערות להוסיף חסר. – אחראיות אחות אחראית </a:t></a:r><a:endParaRPr lang="en-US" sz="1100" dirty="0"><a:effectLst/><a:latin typeface="Calibri" panose="020F0502020204030204" pitchFamily="34" charset="0"/><a:ea typeface="Calibri" panose="020F0502020204030204" pitchFamily="34" charset="0"/><a:cs typeface="Arial" panose="020B0604020202020204" pitchFamily="34" charset="0"/></a:endParaRPr></a:p><a:p><a:pPr><a:buNone/></a:pPr><a:r><a:rPr lang="he-IL" sz="1100" dirty="0"><a:effectLst/><a:ea typeface="Times New Roman" panose="02020603050405020304" pitchFamily="18" charset="0"/><a:cs typeface="Arial" panose="020B0604020202020204" pitchFamily="34" charset="0"/></a:rPr><a:t>לשקול פיתוח מערכת ממוחשבת של צריכה ואספקת תרופות הכוללת התרעה </a:t></a:r><a:endParaRPr lang="en-US" dirty="0"/></a:p></p:txBody></p:sp><p:sp><p:nvSpPr><p:cNvPr id="6" name="כותרת 1"><a:extLst><a:ext uri="{FF2B5EF4-FFF2-40B4-BE49-F238E27FC236}"><a16:creationId xmlns:a16="http://schemas.microsoft.com/office/drawing/2014/main" id="{5150B9E4-5F3E-EFD3-35DE-72770049F451}"/></a:ext></a:extLst></p:cNvPr><p:cNvSpPr txBox="1"><a:spLocks/></p:cNvSpPr><p:nvPr/></p:nvSpPr><p:spPr><a:xfrm><a:off x="4226768" y="35116"/><a:ext cx="7580189" cy="685694"/></a:xfrm><a:prstGeom prst="rect"><a:avLst/></a:prstGeom></p:spPr><p:txBody><a:bodyPr vert="horz" lIns="91440" tIns="45720" rIns="91440" bIns="45720" rtlCol="1" anchor="ctr"><a:normAutofit fontScale="97500" lnSpcReduction="10000"/></a:bodyPr><a:lstStyle><a:lvl1pPr algn="r" defTabSz="914400" rtl="1" eaLnBrk="1" latinLnBrk="0" hangingPunct="1"><a:lnSpc><a:spcPct val="90000"/></a:lnSpc><a:spcBef><a:spcPct val="0"/></a:spcBef><a:buNone/><a:defRPr sz="4400" kern="1200"><a:solidFill><a:schemeClr val="tx1"/></a:solidFill><a:latin typeface="+mj-lt"/><a:ea typeface="+mj-ea"/><a:cs typeface="+mj-cs"/></a:defRPr></a:lvl1pPr></a:lstStyle><a:p><a:pPr algn="ctr"/><a:r><a:rPr lang="he-IL" b="1" dirty="0"><a:solidFill><a:srgbClr val="7030A0"/></a:solidFill><a:latin typeface="David" panose="020E0502060401010101" pitchFamily="34" charset="-79"/><a:cs typeface="D