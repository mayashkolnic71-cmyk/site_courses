                    borderColor: '#06b6d4',
                    backgroundColor: 'transparent',
                    tension: 0.3,
                    borderWidth: 3,
                    pointRadius: 5,
                    pointBackgroundColor: '#06b6d4',
                    pointBorderColor: '#090d16',
                    pointHoverRadius: 7
                }]
            },
            options: {
